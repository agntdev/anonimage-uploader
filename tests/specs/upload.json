[
  {
    "name": "/upload shows upload instructions",
    "steps": [
      {
        "send": { "text": "/upload" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Send me one or more images and I'll upload them anonymously."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "upload menu button shows the same instructions",
    "steps": [
      {
        "send": { "callback": "upload:show" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]
